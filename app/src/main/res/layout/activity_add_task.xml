<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buat Tugas Baru"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Isi detail tugas Anda di bawah ini"
            android:textColor="@color/gray_text"
            android:layout_marginBottom="32dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Judul Tugas"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etTaskTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contoh: Belajar Android"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:textColor="@color/dark_text"
                    android:layout_marginBottom="16dp"
                    android:elevation="1dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tenggat Waktu (Deadline)"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etDeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="YYYY-MM-DD HH:mm"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:textColor="@color/dark_text"
                    android:layout_marginBottom="16dp"
                    android:elevation="1dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prioritas"
                            android:textStyle="bold"
                            android:textColor="@color/dark_text"
                            android:layout_marginBottom="8dp"/>
                        <Spinner
                            android:id="@+id/spPriority"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/card_bg"
                            android:elevation="1dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:textStyle="bold"
                            android:textColor="@color/dark_text"
                            android:layout_marginBottom="8dp"/>
                        <Spinner
                            android:id="@+id/spStatus"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/card_bg"
                            android:elevation="1dp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catatan"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="top"
                    android:hint="Tulis deskripsi tugas di sini..."
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:textColor="@color/dark_text"
                    android:elevation="1dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SIMPAN TUGAS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/primary_blue"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>